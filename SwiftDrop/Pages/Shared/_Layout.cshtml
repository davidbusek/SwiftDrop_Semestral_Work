<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SwiftDrop Nexus</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SwiftDrop.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @inject SwiftDrop.Services.ICartService CartService
    @{
        var cartCount = CartService.GetCart().Sum(c => c.Quantity);
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark glass-panel border-bottom border-secondary mb-4" style="border-radius: 0;">
            <div class="container">
                <a class="navbar-brand text-neon fw-bold tracking-wide" asp-area="" asp-page="/Index">SWIFTDROP</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold text-uppercase" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold text-uppercase" asp-area="" asp-controller="Restaurants" asp-action="Index">Restaurants</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold text-uppercase" asp-area="" asp-page="/Privacy">How it works</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav me-3 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-neon text-uppercase fw-bold" asp-area="" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i> Cart (<span id="cart-count">@cartCount</span>)
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-4">
                                <span class="text-light text-uppercase small">
                                    Status: <span class="text-success fw-bold"><i class="bi bi-shield-check"></i> Verified</span>
                                </span>
                            </li>
                            <li class="nav-item me-3">
                                <span class="text-neon fw-bold fs-5">
                                    <i class="bi bi-person-bounding-box"></i> @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm fw-bold text-uppercase" asp-controller="Account" asp-action="Logout" style="border-radius: 0;">
                                    <i class="bi bi-power"></i> Disconnect
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-white text-uppercase fw-bold hover-neon" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn cyber-btn btn-sm text-uppercase" asp-controller="Account" asp-action="Register">
                                    Initialize User
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - <span class="text-neon">SwiftDrop</span> - <a asp-area="" asp-page="/Privacy" class="text-decoration-none text-neon" style="opacity: 0.8;">Privacy Protocol</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>