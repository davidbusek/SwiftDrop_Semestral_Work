@model SwiftDrop.ViewModels.CreateManagerViewModel
@{
    ViewData["Title"] = "Create Manager";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5" style="max-width: 600px;">
    <h2 class="text-danger mb-4 text-uppercase fw-bold">
        <i class="bi bi-person-plus-fill me-2"></i>Create Manager Account
    </h2>

    <div class="cyber-card p-4 border-danger">
        <form asp-controller="Admin" asp-action="CreateManager" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label asp-for="FirstName" class="form-label text-white text-uppercase small fw-bold">First Name</label>
                    <input asp-for="FirstName" class="form-control bg-dark text-white border-secondary" placeholder="John" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="LastName" class="form-label text-white text-uppercase small fw-bold">Last Name</label>
                    <input asp-for="LastName" class="form-control bg-dark text-white border-secondary" placeholder="Doe" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label text-white text-uppercase small fw-bold">Email</label>
                <input asp-for="Email" class="form-control bg-dark text-white border-secondary" placeholder="manager@restaurant.cz" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label text-white text-uppercase small fw-bold">Password</label>
                <input asp-for="Password" type="password" class="form-control bg-dark text-white border-secondary" placeholder="Min. 6 characters" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="PhoneNumber" class="form-label text-white text-uppercase small fw-bold">Phone (optional)</label>
                <input asp-for="PhoneNumber" class="form-control bg-dark text-white border-secondary" placeholder="+420 777 000 000" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn cyber-btn text-uppercase fw-bold px-4">
                    <i class="bi bi-person-check-fill me-1"></i>Create
                </button>
                <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary text-uppercase fw-bold px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
