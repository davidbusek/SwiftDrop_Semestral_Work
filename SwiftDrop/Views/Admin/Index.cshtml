@model SwiftDrop.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "System Administration";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* Make all admin tabs consistently red; Bootstrap's default active colour would override text-danger */
        #adminTabs .nav-link {
            color: #dc3545;
            border-color: transparent;
            background: transparent;
        }
        #adminTabs .nav-link:hover {
            color: #ff6b7a;
            border-color: transparent;
        }
        #adminTabs .nav-link.active {
            color: #dc3545 !important;
            background: rgba(220, 53, 69, 0.1) !important;
            border-color: #dc3545 #dc3545 transparent !important;
        }
    </style>
}

<div class="container my-5">
    <h2 class="text-danger mb-4 text-uppercase fw-bold"><i class="bi bi-shield-lock-fill me-2"></i>Admin Override</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert border-0 mb-4" style="background:rgba(57,255,20,0.1); color:#39ff14; border-left:3px solid #39ff14 !important;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }

    @* Stats row *@
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="cyber-card p-4 border-danger">
                <h5 class="text-white opacity-75">Total Users</h5>
                <h2 class="text-neon fw-bold">@Model.TotalUsers</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-4 border-danger">
                <h5 class="text-white opacity-75">Active Nodes</h5>
                <h2 class="text-neon fw-bold">@Model.ActiveRestaurants</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-4 border-danger">
                <h5 class="text-white opacity-75">Daily Creds</h5>
                <h2 class="text-neon fw-bold">@Model.DailyRevenue.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="cyber-card p-4 border-danger">
                <h5 class="text-white opacity-75">Total Orders</h5>
                <h2 class="text-neon fw-bold">@Model.TotalOrders</h2>
            </div>
        </div>
    </div>

    @* Tab nav *@
    <ul class="nav nav-tabs border-danger mb-4" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active text-uppercase fw-bold" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                <i class="bi bi-people-fill me-1"></i>Users
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-uppercase fw-bold" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">
                <i class="bi bi-box-seam me-1"></i>Orders
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-uppercase fw-bold" id="restaurants-tab" data-bs-toggle="tab" data-bs-target="#restaurants" type="button" role="tab">
                <i class="bi bi-shop me-1"></i>Restaurants
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-uppercase fw-bold" id="foods-tab" data-bs-toggle="tab" data-bs-target="#foods" type="button" role="tab">
                <i class="bi bi-egg-fried me-1"></i>Foods
            </button>
        </li>
    </ul>

    <div class="tab-content" id="adminTabContent">

        @* ── USERS TAB ── *@
        <div class="tab-pane fade show active" id="users" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="text-danger text-uppercase mb-0">User Database</h4>
                <a asp-controller="Admin" asp-action="CreateManager" class="btn cyber-btn btn-sm text-uppercase">
                    <i class="bi bi-person-plus-fill me-1"></i>Add Manager
                </a>
            </div>
            <div class="cyber-card p-4 border-danger">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                        <thead>
                            <tr class="text-uppercase">
                                <th class="ps-0 border-top-0 bg-transparent text-white">ID</th>
                                <th class="border-top-0 bg-transparent text-white">Name</th>
                                <th class="border-top-0 bg-transparent text-white">Email</th>
                                <th class="border-top-0 bg-transparent text-white">Role</th>
                                <th class="border-top-0 bg-transparent text-white">Registered</th>
                                <th class="border-top-0 bg-transparent text-white text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr class="border-bottom border-secondary bg-transparent">
                                    <td class="ps-0 text-white">@user.Id</td>
                                    <td class="text-white">@user.FirstName @user.LastName</td>
                                    <td class="text-white opacity-75">@user.Email</td>
                                    <td class="text-neon">@user.Role</td>
                                    <td class="text-white opacity-75">@user.RegisteredAt?.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end pe-0">
                                        @if (user.Role != "Admin")
                                        {
                                            <form method="post" asp-controller="Admin" asp-action="DeleteUser" class="m-0 d-inline"
                                                  onsubmit="return confirm('Terminate user @user.FirstName @user.LastName?');">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger text-uppercase">Terminate</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── ORDERS TAB ── *@
        <div class="tab-pane fade" id="orders" role="tabpanel">
            <h4 class="text-danger text-uppercase mb-3">Recent Orders</h4>
            <div class="cyber-card p-4 border-danger">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                        <thead>
                            <tr class="text-uppercase">
                                <th class="ps-0 border-top-0 bg-transparent text-white">ID</th>
                                <th class="border-top-0 bg-transparent text-white">Customer</th>
                                <th class="border-top-0 bg-transparent text-white">Address</th>
                                <th class="border-top-0 bg-transparent text-white">Status</th>
                                <th class="border-top-0 bg-transparent text-white">Total</th>
                                <th class="border-top-0 bg-transparent text-white">Created</th>
                                <th class="border-top-0 bg-transparent text-white text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                var statusClass = order.Status switch
                                {
                                    "Delivered"  => "text-success",
                                    "Canceled"   => "text-danger",
                                    "Delivering" => "text-info",
                                    _            => "text-warning"
                                };
                                var state = SwiftDrop.Services.OrderStates.OrderStateFactory.GetState(order.Status);
                                <tr class="border-bottom border-secondary bg-transparent">
                                    <td class="ps-0 text-white">#@order.Id</td>
                                    <td class="text-white">@order.User?.FirstName @order.User?.LastName</td>
                                    <td class="text-white opacity-75">@order.Address?.Street, @order.Address?.City</td>
                                    <td><span class="@statusClass fw-bold">@order.Status</span></td>
                                    <td class="text-neon">@order.TotalPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</td>
                                    <td class="text-white opacity-75">@order.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="text-end pe-0">
                                        @if (state.CanAdvance)
                                        {
                                            <form method="post" asp-controller="Admin" asp-action="AdvanceOrderState" class="m-0 d-inline">
                                                <input type="hidden" name="id" value="@order.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning text-uppercase">
                                                    <i class="bi bi-arrow-right-circle me-1"></i>Advance
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-secondary small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── RESTAURANTS TAB ── *@
        <div class="tab-pane fade" id="restaurants" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="text-danger text-uppercase mb-0">Restaurants</h4>
                <a asp-controller="Admin" asp-action="CreateRestaurant" class="btn cyber-btn btn-sm text-uppercase">
                    <i class="bi bi-plus-circle-fill me-1"></i>Add Restaurant
                </a>
            </div>
            <div class="cyber-card p-4 border-danger">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                        <thead>
                            <tr class="text-uppercase">
                                <th class="ps-0 border-top-0 bg-transparent text-white">ID</th>
                                <th class="border-top-0 bg-transparent text-white">Name</th>
                                <th class="border-top-0 bg-transparent text-white">Address</th>
                                <th class="border-top-0 bg-transparent text-white">Rating</th>
                                <th class="border-top-0 bg-transparent text-white">Status</th>
                                <th class="border-top-0 bg-transparent text-white text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Restaurants)
                            {
                                <tr class="border-bottom border-secondary bg-transparent">
                                    <td class="ps-0 text-white">@r.Id</td>
                                    <td class="text-white">@r.Name</td>
                                    <td class="text-white opacity-75">@r.Address?.Street, @r.Address?.City</td>
                                    <td class="text-neon">@(r.AverageRating?.ToString("0.0") ?? "—") ★</td>
                                    <td>
                                        @if (r.IsActive == true)
                                        {
                                            <span class="text-success fw-bold">Active</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end pe-0">
                                        <form method="post" asp-controller="Admin" asp-action="DeleteRestaurant" class="m-0 d-inline"
                                              onsubmit="return confirm('Delete restaurant @r.Name and all its menu items?');">
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger text-uppercase">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── FOODS TAB ── *@
        <div class="tab-pane fade" id="foods" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="text-danger text-uppercase mb-0">Menu Items</h4>
                <div class="d-flex gap-2">
                    <a asp-controller="Admin" asp-action="CreateCategory" class="btn btn-outline-danger btn-sm text-uppercase">
                        <i class="bi bi-tag-fill me-1"></i>Add Category
                    </a>
                    <a asp-controller="Admin" asp-action="CreateMenuItem" class="btn cyber-btn btn-sm text-uppercase">
                        <i class="bi bi-plus-circle-fill me-1"></i>Add Food Item
                    </a>
                </div>
            </div>
            <div class="cyber-card p-4 border-danger">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                        <thead>
                            <tr class="text-uppercase">
                                <th class="ps-0 border-top-0 bg-transparent text-white">ID</th>
                                <th class="border-top-0 bg-transparent text-white">Name</th>
                                <th class="border-top-0 bg-transparent text-white">Restaurant</th>
                                <th class="border-top-0 bg-transparent text-white">Category</th>
                                <th class="border-top-0 bg-transparent text-white">Price</th>
                                <th class="border-top-0 bg-transparent text-white">Available</th>
                                <th class="border-top-0 bg-transparent text-white text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.MenuItems)
                            {
                                <tr class="border-bottom border-secondary bg-transparent">
                                    <td class="ps-0 text-white">@item.Id</td>
                                    <td class="text-white">@item.Name</td>
                                    <td class="text-white opacity-75">@item.Category?.Restaurant?.Name</td>
                                    <td class="text-white opacity-75">@item.Category?.Name</td>
                                    <td class="text-neon">@item.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</td>
                                    <td>
                                        @if (item.IsAvailable == true)
                                        {
                                            <span class="text-success fw-bold">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">No</span>
                                        }
                                    </td>
                                    <td class="text-end pe-0">
                                        <form method="post" asp-controller="Admin" asp-action="DeleteMenuItem" class="m-0 d-inline"
                                              onsubmit="return confirm('Delete menu item @item.Name?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger text-uppercase">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>@* /tab-content *@
</div>

@section Scripts {
    <script>
        // Restore the active tab after a page reload caused by a form post
        const tabKey = 'adminActiveTab';
        const stored = sessionStorage.getItem(tabKey);
        if (stored) {
            const el = document.querySelector(`[data-bs-target="${stored}"]`);
            if (el) bootstrap.Tab.getOrCreateInstance(el).show();
        }
        document.querySelectorAll('#adminTabs [data-bs-toggle="tab"]').forEach(btn => {
            btn.addEventListener('shown.bs.tab', e => {
                sessionStorage.setItem(tabKey, e.target.getAttribute('data-bs-target'));
            });
        });
    </script>
}
