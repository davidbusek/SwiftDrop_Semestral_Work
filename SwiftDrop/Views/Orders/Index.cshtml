@model SwiftDrop.ViewModels.MyOrdersViewModel
@{
    ViewData["Title"] = "My Requisitions";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="text-neon mb-4 text-uppercase fw-bold"><i class="bi bi-clock-history me-2"></i>Requisition History</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-neon border-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger bg-dark border-danger mb-4">
            <i class="bi bi-x-circle-fill me-2"></i>@TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info bg-dark text-white border-neon shadow">
            No past requisitions found in your databanks. Visit <a asp-controller="Restaurants" asp-action="Index" class="text-neon fw-bold text-decoration-none">Restaurants</a> to initialize an order.
        </div>
    }
    else
    {
        <div class="cyber-card p-4 border-neon shadow">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                    <thead>
                        <tr class="border-secondary text-uppercase text-neon">
                            <th class="ps-0 border-top-0 bg-transparent text-white">Order ID</th>
                            <th class="border-top-0 bg-transparent text-white">Date Initiated</th>
                            <th class="border-top-0 bg-transparent text-white">Total Creds</th>
                            <th class="border-top-0 bg-transparent text-white text-end pe-0">Status</th>
                            <th class="border-top-0 bg-transparent"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr class="border-bottom border-secondary bg-transparent">
                                <td class="ps-0 text-white opacity-75">#@order.Id</td>
                                <td class="text-light">@order.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-neon fw-bold">@order.TotalPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</td>
                                <td class="text-end pe-0">
                                    @{
                                        var rawStatus = string.IsNullOrWhiteSpace(order.Status) ? "Delivered" : order.Status;
                                        var displayStatus = rawStatus.Replace("PickupsInProgress", "Pickup In Progress").Replace("CourierAssigned", "Courier Assigned");
                                        var badgeColor = rawStatus == "Delivered" ? "text-success border-success" : 
                                                         rawStatus == "Canceled" ? "text-danger border-danger" : 
                                                         "text-warning border-warning";
                                    }
                                    <span class="badge bg-dark border @badgeColor text-uppercase">
                                        @displayStatus
                                    </span>
                                </td>
                                <td class="text-end pe-0">
                                    <a asp-action="Track" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-secondary text-neon border-neon py-0 me-1">
                                        <i class="bi bi-geo-alt"></i>
                                    </a>
                                    @if (order.Status == SwiftDrop.Models.OrderStatus.Pending || order.Status == SwiftDrop.Models.OrderStatus.Paid)
                                    {
                                        <form method="post" asp-action="Cancel" asp-route-id="@order.Id" class="d-inline m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0"
                                                    onclick="return confirm('Cancel order #@order.Id? This cannot be undone.')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>