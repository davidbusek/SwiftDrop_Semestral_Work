@model SwiftDrop.ViewModels.CourierDashboardViewModel
@{
    ViewData["Title"] = "Active Deliveries";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    <style>
        #courierMap {
            height: 400px;
            width: 100%;
            border-radius: 8px;
            border: 1px solid var(--bs-info);
            margin-bottom: 2rem;
            z-index: 1; /* Keeping it from overlapping modals/dropdowns */
        }
        .leaflet-routing-container {
            display: none !important;
        }
    </style>
}

<div class="container my-5">
    <h2 class="text-info mb-4 text-uppercase fw-bold"><i class="bi bi-bicycle me-2"></i>Courier Grid</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="cyber-card p-4 border-info">
                <h5 class="text-white opacity-75">Active Delivery Jobs</h5>
                <h2 class="text-neon fw-bold">@Model.ActiveJobs <i class="bi bi-box-seam float-end text-info"></i></h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="cyber-card p-4 border-info">
                <h5 class="text-white opacity-75">Shift Earnings</h5>
                <h2 class="text-neon fw-bold">@Model.CurrentEarnings.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</h2>
            </div>
        </div>
    </div>

    <!-- Live Routing Map -->
    <h4 class="text-info border-bottom border-info pb-2 text-uppercase mb-3">Live Navigation System (OSM/Leaflet)</h4>
    <div class="cyber-card p-4 border-info mb-5">
        <div id="courierMap"></div>
    </div>

    <!-- Active Delivery Jobs Management -->
    <h4 class="text-info border-bottom border-info pb-2 text-uppercase mb-3">Available Parcels</h4>
    <div class="cyber-card p-4 border-info">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead>
                    <tr class="border-info text-uppercase text-info">
                        <th class="ps-0 border-top-0 bg-transparent text-white">Order ID</th>
                        <th class="border-top-0 bg-transparent text-white">Customer Address</th>
                        <th class="border-top-0 bg-transparent text-white">Order Time</th>
                        <th class="border-top-0 bg-transparent text-white">Payout</th>
                        <th class="border-top-0 bg-transparent text-white">Status</th>
                        <th class="border-top-0 bg-transparent text-white text-center">Route</th>
                        <th class="border-top-0 bg-transparent text-white text-end pe-0">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.AvailableOrders.Any())
                    {
                        <tr><td colspan="7" class="text-center text-white opacity-50 py-3">No active parcels to deliver.</td></tr>
                    }
                    @foreach (var order in Model.AvailableOrders)
                    {
                        <tr class="border-bottom border-secondary bg-transparent">
                            <td class="ps-0 text-white">
                                #@order.Id
                                <div class="mt-2">
                                    <small class="text-neon d-block mb-1">Contents:</small>
                                    <ul class="list-unstyled text-light opacity-75 mb-0" style="font-size: 0.85rem;">
                                        @foreach (var sub in order.Suborders)
                                        {
                                            foreach (var item in sub.Orderitems)
                                            {
                                                <li>- @item.Quantity x @(item.MenuItem?.Name ?? "Item")</li>
                                            }
                                        }
                                    </ul>
                                </div>
                            </td>
                            <td class="text-light opacity-75">
                                @if(order.Address != null)
                                {
                                    <span>@order.Address.Street, @order.Address.City (@order.Address.ZipCode)</span>
                                }
                                else
                                {
                                    <span>Unknown Vector</span>
                                }
                            </td>
                            <td class="text-light opacity-75">@order.CreatedAt?.ToString("HH:mm")</td>
                            <td class="text-success fw-bold">
                                + @((order.DeliveryFee * 0.8m).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)) Kč
                            </td>
                            <td>
                                @{
                                    var displayStatus = order.Status == "CourierAssigned" ? "Awaiting Courier" : 
                                                        order.Status == "Delivering" ? "Accepted / Delivering" : order.Status;
                                }
                                <span class="badge bg-info text-dark text-uppercase border border-info">@displayStatus</span>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm cyber-btn bg-info text-dark text-uppercase fw-bold view-map-btn" data-order-id="@order.Id">
                                    <i class="bi bi-geo-alt"></i> Show Route
                                </button>
                            </td>
                            <td class="text-end pe-0">
                                <form method="post" asp-controller="Courier" asp-action="UpdateDeliveryState" class="m-0 d-inline">
                                    <input type="hidden" name="id" value="@order.Id" />
                                    @if(order.Status == "CourierAssigned")
                                    {
                                        <button type="submit" class="btn btn-sm cyber-btn bg-info text-dark text-uppercase fw-bold"><i class="bi bi-bicycle"></i> Accept Job</button>
                                    }
                                    else if(order.Status == "Delivering")
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success text-uppercase fw-bold"><i class="bi bi-check-circle"></i> Complete</button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // We use exact property names as output by JsonSerializer without modifying naming policy, so 'OrderId' works.
            var rawMarkersData = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MapMarkers ?? new List<SwiftDrop.ViewModels.MapMarkerDto>()))';
            var allMarkers = JSON.parse(rawMarkersData);

            // Set initial map view to Prague
            var map = L.map('courierMap').setView([50.08, 14.43], 12);

            // Load map tiles from OpenStreetMap
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                className: 'map-tiles-cyber'
            }).addTo(map);

            var currentLayerGroup = L.layerGroup().addTo(map);
            var routingControl = null;

            function showOrderOnMap(orderId) {
                currentLayerGroup.clearLayers();
                if (routingControl != null) {
                    map.removeControl(routingControl);
                    routingControl = null;
                }

                var bounds = [];
                var waypoints = [];

                // Filtering based on exact property casing from C# ViewModels
                var orderMarkers = allMarkers.filter(function(m) { return m.OrderId === orderId; });

                // Sort by optimized RouteOrder
                orderMarkers.sort(function(a, b) { return a.RouteOrder - b.RouteOrder; });

                // Iterate over markers and render them
                orderMarkers.forEach(function(m) {
                    var isPickup = m.Type === 'Pickup';
                    // Different colors for pickup and delivery
                    var markerColor = isPickup ? '#ffc107' : '#DC3545'; // Yellow/Neon for Pickup, Red for Dropoff
                    var radiusSize = isPickup ? 10 : 8;

                    var circleMarker = L.circleMarker([m.Lat, m.Lng], {
                        color: markerColor,
                        fillColor: markerColor,
                        fillOpacity: 0.8,
                        radius: radiusSize
                    });

                    // Include route order number in popup
                    circleMarker.bindPopup('<strong style="color: black;">' + m.RouteOrder + '. ' + m.Title + '</strong><br>' + m.Type);
                    currentLayerGroup.addLayer(circleMarker);

                    bounds.push([m.Lat, m.Lng]);
                    waypoints.push(L.latLng(m.Lat, m.Lng));
                });

                // Draw actual street Route connecting the stops via OSRM
                if (waypoints.length > 1) {
                    routingControl = L.Routing.control({
                        waypoints: waypoints,
                        router: L.Routing.osrmv1({
                            serviceUrl: 'https://router.project-osrm.org/route/v1'
                        }),
                        lineOptions: {
                            styles: [{ color: '#0dcaf0', opacity: 0.8, weight: 5 }]
                        },
                        show: false, 
                        addWaypoints: false,
                        routeWhileDragging: false,
                        fitSelectedRoutes: false,
                        createMarker: function() { return null; } 
                    }).addTo(map);
                }

                // Zoom to fit all bounds if they exist
                if(bounds.length > 0) {
                    map.fitBounds(bounds, { padding: [50, 50] });
                    document.getElementById('courierMap').scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                    alert('No GPS coordinates found for this order.');
                }
            }

            // Click listener for all "Show Route" buttons
            var mapButtons = document.querySelectorAll('.view-map-btn');
            mapButtons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var oId = parseInt(this.getAttribute('data-order-id'));
                    showOrderOnMap(oId);
                });
            });
        });
    </script>
}