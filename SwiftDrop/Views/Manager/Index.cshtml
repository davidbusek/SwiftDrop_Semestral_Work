@model SwiftDrop.ViewModels.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Restaurant Management";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <h2 class="text-warning mb-4 text-uppercase fw-bold"><i class="bi bi-shop me-2"></i>Manager Dashboard</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert border-0 mb-4" style="background:rgba(57,255,20,0.1); color:#39ff14; border-left:3px solid #39ff14 !important;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="cyber-card p-4 border-warning">
                <h5 class="text-white opacity-75">Pending Orders <i class="bi bi-exclamation-circle text-warning float-end"></i></h5>
                <h2 class="text-neon fw-bold">@Model.PendingOrders</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="cyber-card p-4 border-warning">
                <h5 class="text-white opacity-75">Total Menu Items Listed</h5>
                <h2 class="text-neon fw-bold">@Model.ActiveItems</h2>
            </div>
        </div>
    </div>

    <!-- Active Orders Management -->
    <h4 class="text-warning border-bottom border-warning pb-2 text-uppercase mb-3">Incoming Requisitions</h4>
    <div class="cyber-card p-4 border-warning mb-5">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead>
                    <tr class="border-warning text-uppercase text-warning">
                        <th class="ps-0 border-top-0 bg-transparent text-white">Order ID</th>
                        <th class="border-top-0 bg-transparent text-white">Customer</th>
                        <th class="border-top-0 bg-transparent text-white">Total</th>
                        <th class="border-top-0 bg-transparent text-white">Time</th>
                        <th class="border-top-0 bg-transparent text-white">Status</th>
                        <th class="border-top-0 bg-transparent text-white text-end pe-0">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Orders.Any())
                    {
                        <tr><td colspan="6" class="text-center text-white opacity-50 py-3">No pending orders found.</td></tr>
                    }
                    @foreach (var order in Model.Orders)
                    {
                        <tr class="border-bottom border-secondary bg-transparent">
                            <td class="ps-0 text-white">#@order.Id</td>
                            <td class="text-white">@(order.User?.FirstName ?? "Unknown")</td>
                            <td class="text-neon fw-bold">@order.TotalPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</td>
                            <td class="text-light opacity-75">@order.CreatedAt?.ToString("HH:mm")</td>
                            <td><span class="badge bg-warning text-dark text-uppercase border border-warning">@order.Status?.Replace("PickupsInProgress", "Pickup In Progress").Replace("CourierAssigned", "Courier Assigned")</span></td>
                            <td class="text-end pe-0">
                                <form method="post" asp-controller="Manager" asp-action="AdvanceOrderState" class="m-0 d-inline">
                                    <input type="hidden" name="id" value="@order.Id" />
                                    @if(order.Status == "Pending" || order.Status == "Paid")
                                    {
                                        <button type="submit" class="btn btn-sm cyber-btn bg-warning text-dark text-uppercase fw-bold"><i class="bi bi-fire"></i> Start Prep</button>
                                    }
                                    else if(order.Status == "PickupsInProgress")
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success text-uppercase fw-bold"><i class="bi bi-box-seam"></i> Ready for Courier</button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Active Menu Items Management -->
    <div class="d-flex justify-content-between align-items-center border-bottom border-warning pb-2 mb-3">
        <h4 class="text-warning text-uppercase mb-0">Menu Directory</h4>
        <div class="d-flex gap-2">
            <a asp-controller="Manager" asp-action="CreateCategory" class="btn btn-warning btn-sm text-dark text-uppercase fw-bold">
                <i class="bi bi-tag-fill me-1"></i>Add Category
            </a>
            <a asp-controller="Manager" asp-action="CreateMenuItem" class="btn btn-outline-warning btn-sm text-uppercase fw-bold">
                <i class="bi bi-plus-circle-fill me-1"></i>Add Food Item
            </a>
        </div>
    </div>
    <div class="cyber-card p-4 border-warning">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead>
                    <tr class="border-warning text-uppercase text-warning">
                        <th class="ps-0 border-top-0 bg-transparent text-white">ID</th>
                        <th class="border-top-0 bg-transparent text-white">Name</th>
                        <th class="border-top-0 bg-transparent text-white">Category</th>
                        <th class="border-top-0 bg-transparent text-white">Price</th>
                        <th class="border-top-0 bg-transparent text-white text-end pe-0">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.MenuItems.Any())
                    {
                        <tr><td colspan="5" class="text-center text-white opacity-50 py-3">No menu items configured.</td></tr>
                    }
                    @foreach (var item in Model.MenuItems)
                    {
                        <tr class="border-bottom border-secondary bg-transparent">
                            <td class="ps-0 text-white opacity-50">@item.Id</td>
                            <td class="text-white fw-bold">@item.Name</td>
                            <td class="text-white opacity-75">@item.Category?.Name</td>
                            <td class="text-light">@item.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) Kč</td>
                            <td class="text-end pe-0">
                                <form method="post" asp-controller="Manager" asp-action="DeleteMenuItem" class="m-0 d-inline" onsubmit="return confirm('Remove @(item.Name.Replace("'", "")) from directory?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger text-uppercase"><i class="bi bi-trash"></i> Drop</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>