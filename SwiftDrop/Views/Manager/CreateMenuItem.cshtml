@model SwiftDrop.ViewModels.CreateMenuItemViewModel
@{
    ViewData["Title"] = "Add Food Item";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5" style="max-width: 650px;">
    <h2 class="text-warning mb-4 text-uppercase fw-bold">
        <i class="bi bi-plus-circle-fill me-2"></i>Add Food Item
    </h2>

    <div class="cyber-card p-4 border-warning">
        <form asp-controller="Manager" asp-action="CreateMenuItem" method="post">
            <div asp-validation-summary="ModelOnly" class="text-warning mb-3 small"></div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label text-white text-uppercase small fw-bold">Category</label>
                @if (Model.Categories.Count == 0)
                {
                    <div class="text-warning small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        No categories found for your restaurant.
                        <a asp-controller="Manager" asp-action="CreateCategory" class="text-neon">Create a category first.</a>
                    </div>
                }
                else
                {
                    <select asp-for="CategoryId" class="form-select bg-dark text-white border-secondary">
                        <option value="">— select a category —</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Restaurant?.Name – @cat.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-warning small"></span>
                }
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label text-white text-uppercase small fw-bold">Item Name</label>
                <input asp-for="Name" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Margherita" />
                <span asp-validation-for="Name" class="text-warning small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label text-white text-uppercase small fw-bold">Description (optional)</label>
                <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="Short description…"></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-4">
                    <label asp-for="Price" class="form-label text-white text-uppercase small fw-bold">Price (Kč)</label>
                    <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control bg-dark text-white border-secondary" placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-warning small"></span>
                </div>
                <div class="col-sm-4">
                    <label asp-for="WeightOrVolume" class="form-label text-white text-uppercase small fw-bold">Weight / Volume</label>
                    <input asp-for="WeightOrVolume" class="form-control bg-dark text-white border-secondary" placeholder="300 g" />
                </div>
                <div class="col-sm-4">
                    <label asp-for="Allergens" class="form-label text-white text-uppercase small fw-bold">Allergens</label>
                    <input asp-for="Allergens" class="form-control bg-dark text-white border-secondary" placeholder="1,3,7" />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="ImageUrl" class="form-label text-white text-uppercase small fw-bold">Image URL (optional)</label>
                <input asp-for="ImageUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://…" />
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-warning text-dark text-uppercase fw-bold px-4"
                        @(Model.Categories.Count == 0 ? "disabled" : "")>
                    <i class="bi bi-check-circle-fill me-1"></i>Save Item
                </button>
                <a asp-controller="Manager" asp-action="Index" class="btn btn-outline-secondary text-uppercase fw-bold px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
